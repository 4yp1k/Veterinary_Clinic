<Window x:Class="Veterinary_Clinic.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Veterinary_Clinic"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        mc:Ignorable="d"
        Title="VetClinic System"
        Height="600"
        Width="1000"
        Background="#F4F6F9" MinWidth="650" MinHeight="400">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="117*"/>
            <ColumnDefinition Width="133*"/>
        </Grid.ColumnDefinitions>
        <Border Background="#2D3E50" Height="60" VerticalAlignment="Top" Grid.ColumnSpan="2">
            <StackPanel Orientation="Horizontal" Margin="10,0,0,10">
                <TextBlock Text="🐾 VetClinic Management System"
                    Foreground="White"
                    FontSize="20"
                    FontWeight="Bold" Margin="0,15,0,5"/>

            </StackPanel>
        </Border>

        <Button x:Name="AdminButton" Content="👤 Войти как админ" Click="AdminMode_Click"  Foreground="#FF2D3E50" Background="White" Grid.Column="1" Margin="0,14,30,0" Width="150" Height="30" VerticalAlignment="Top" HorizontalAlignment="Right" />

        <TabControl Margin="10,70,10,10" Grid.ColumnSpan="2" Name="tabControl">

            <TabItem Header="🐶 Животные" Height="22" Margin="-2,0,-2,0" VerticalAlignment="Top">
                <Grid Margin="10">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10" Grid.ColumnSpan="2">
                        <Button x:Name="AddAnimalButton" Content="➕ Добавить" Click="AddAnimal_Click"/>

                        <Button Content="✏ Изменить" Click="EditAnimal_Click"/>

                        <Button x:Name="DeleteAnimalButton" Content="🗑 Удалить" Click="DeleteAnimal_Click"/>

                        <xctk:WatermarkTextBox x:Name="SearchBoxAn" Watermark="Поиск..." TextChanged="SearchBoxAn_TextChanged" />
                    </StackPanel>

                    <DataGrid x:Name="AnimalsGrid"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single" Grid.ColumnSpan="2">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Имя" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Вид" Binding="{Binding Species}" Width="*"/>
                            <DataGridTextColumn Header="Дата рождения" Binding="{Binding Age, StringFormat=dd.MM.yyyy}" Width="*"/>
                            <DataGridTextColumn Header="Владелец" Binding="{Binding Owner.FullName}" Width="2*"/>
                        </DataGrid.Columns>

                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="👤 Владельцы">
                <Grid Margin="10">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="➕ Добавить" Click="AddOwner_Click"/>
                        <Button Content="✏ Изменить" Click="EditOwner_Click"/>
                        <Button x:Name="DeleteOwnerButton" Content="🗑 Удалить" Click="DeleteOwner_Click"/>

                        <xctk:WatermarkTextBox x:Name="SearchBoxOw" Watermark="Поиск..." TextChanged="SearchBoxOw_TextChanged" />
                    </StackPanel>

                    <DataGrid x:Name="OwnersGrid"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="2*"/>
                            <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="*"/>
                            <DataGridTextColumn Header="Адрес" Binding="{Binding Address}" Width="2*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                </Grid>
            </TabItem>

            <TabItem x:Name="VetsTab" Header="👨‍⚕ Ветеринары">
                <Grid Margin="10">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button x:Name="AddVetsButton" Content="➕ Добавить" Click="AddVet_Click"/>
                        <Button x:Name="EditVetsButton" Content="✏ Изменить" Click="EditVet_Click"/>
                        <Button x:Name="DeleteVetsButton" Content="🗑 Удалить" Click="DeleteVet_Click"/>

                        <xctk:WatermarkTextBox x:Name="SearchBoxVt" Watermark="Поиск..." TextChanged="SearchBoxVt_TextChanged" />
                    </StackPanel>

                    <DataGrid x:Name="VetsGrid"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="2*"/>
                            <DataGridTextColumn Header="Специализация" Binding="{Binding Specialty}" Width="2*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                </Grid>
            </TabItem>

            <TabItem Header="📅 Приёмы">
                <Grid Margin="10">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="➕ Добавить" Click="AddAppointment_Click"/>
                        <Button Content="✏ Изменить" Click="EditAppointment_Click"/>
                        <Button x:Name="DeleteAppointButton" Content="🗑 Удалить" Click="DeleteAppointment_Click"/>

                        <xctk:WatermarkTextBox x:Name="SearchBoxAp" Watermark="Поиск..." TextChanged="SearchBoxAp_TextChanged" />
                    </StackPanel>

                    <DataGrid x:Name="AppointmentsGrid"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  IsReadOnly="True">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Животное" Binding="{Binding Animal.Name}" Width="*"/>
                            <DataGridTextColumn Header="Врач" Binding="{Binding DoctorName}" Width="*"/>
                            <DataGridTextColumn Header="Дата" Binding="{Binding VisitDate, StringFormat=dd.MM.yyyy HH.mm}" Width="*"/>
                            <DataGridTextColumn Header="Жалоба" Binding="{Binding Complaint}" Width="2*"/>
                        </DataGrid.Columns>

                    </DataGrid>

                </Grid>
            </TabItem>

            <TabItem Header="💊 Лечение">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10" Grid.ColumnSpan="2">
                        <Button Content="➕ Добавить" Click="AddTreatment_Click"/>
                        <Button Content="✏ Изменить" Click="EditTreatment_Click"/>
                        <Button x:Name="DeleteTreatButton" Content="🗑 Удалить" Click="DeleteTreatment_Click"/>

                        <xctk:WatermarkTextBox x:Name="SearchBoxTr" Watermark="Поиск..." TextChanged="WatermarkTextBox_TextChanged" />
                    </StackPanel>

                    <DataGrid x:Name="TreatmentsGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True" Grid.ColumnSpan="2" Margin="0,51,0,0" Grid.RowSpan="2">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Животное" Binding="{Binding AnimalName}" Width="*"/>
                            <DataGridTextColumn Header="Врач" Binding="{Binding VetName}" Width="*"/>
                            <DataGridTextColumn Header="Диагноз" Binding="{Binding Diagnosis}" Width="2*"/>
                            <DataGridTextColumn Header="Лечение" Binding="{Binding TreatmentPlan}" Width="2*"/>
                            <DataGridTextColumn Header="Дата" Binding="{Binding DateCreated, StringFormat=dd.MM.yyyy HH.mm}" Width="*"/>
                            <DataGridTextColumn Header="Стоимость" Binding="{Binding Cost}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="💰 Выручка" Name="RevenueVetTab">

                <Grid Margin="10">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">

                        <Button Content="Загрузить"
                    Click="LoadRevenueByVets_Click"
                    Width="140"/>

                        <TextBlock x:Name="TotalText"
                       Margin="20,8,0,0"
                       FontSize="16"
                       FontWeight="Bold"/>

                    </StackPanel>

                    <DataGrid x:Name="RevenueVetGrid"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  IsReadOnly="True">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Дата"
                                    Binding="{Binding Day, StringFormat=dd.MM.yyyy}"
                                    Width="*"/>

                            <DataGridTextColumn Header="Врач"
                                    Binding="{Binding VetName}"
                                    Width="2*"/>

                            <DataGridTextColumn Header="Выручка"
                                    Binding="{Binding Total}"
                                    Width="*"/>
                        </DataGrid.Columns>

                    </DataGrid>

                </Grid>

            </TabItem>
        </TabControl>
    </Grid>
</Window>