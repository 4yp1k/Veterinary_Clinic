<Window x:Class="Veterinary_Clinic.AppointmentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Veterinary_Clinic" xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="Приём"
        Height="445"
        Width="420"
        WindowStartupLocation="CenterScreen"
        Background="#F4F6F9" MinWidth="420" MinHeight="445">

    <Border Margin="15" Padding="15" Background="White" CornerRadius="10">

        <StackPanel>

            <TextBlock Text="📅 Приём"
                       FontSize="18"
                       FontWeight="Bold"
                       Margin="0,0,0,15"/>

            <TextBlock Text="Животное"/>
            <ComboBox x:Name="AnimalBox"
                      DisplayMemberPath="Name"
                      SelectedValuePath="Id"/>

            <TextBlock Text="Ветеринар"/>
            <ComboBox x:Name="VetBox" SelectedValuePath="Id">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding FullName}" FontWeight="Bold"/>
                            <TextBlock Text=" ("/>
                            <TextBlock Text="{Binding Specialty}" Foreground="Gray"/>
                            <TextBlock Text=")"/>
                        </StackPanel>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <TextBlock Text="Дата"/>
            <xctk:DateTimePicker x:Name="DatePickerBox" Format="Custom"
                     FormatString="dd.MM.yyyy HH:mm" Minimum="{x:Static sys:DateTime.Now}"/>

            <TextBlock Text="Жалоба"/>
            <TextBox x:Name="ComplaintBox"/>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,20,0,0">

                <Button Content="Сохранить" Width="110" Click="Save_Click"/>
                <Button Content="Отмена" Width="110" Click="Cancel_Click"/>

            </StackPanel>

        </StackPanel>

    </Border>
</Window>
