<Window x:Class="Veterinary_Clinic.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Veterinary_Clinic.Views"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        mc:Ignorable="d"
        Title="Логин" Height="281" Width="338" MinWidth="338" MinHeight="281">

    <Grid Margin="10">
        <Border Background="#2D3E50" Height="50" VerticalAlignment="Center">
            <TextBlock Text="🐾 VetClinic Management System"
            Foreground="White"
            VerticalAlignment="Center"
            Margin="10,0,11,0"
            FontSize="16"
            FontWeight="Bold"/>
        </Border>

        <xctk:WatermarkTextBox x:Name="UsernameBox" Grid.Row="1"
         Margin="30,13,48,10" Width="NaN" Height="40" Watermark="Логин" FontSize="11" VerticalContentAlignment="Center"/>
        
        <xctk:WatermarkTextBox x:Name="WatermarkPasswordBox" Grid.Row="2"
            Margin="30,6,48,10" Width="NaN" Height="40" Watermark="Пароль" FontSize="11" VerticalContentAlignment="Center"/>
        
        <PasswordBox x:Name="PasswordBox" Grid.Row="2"
            Margin="30,6,48,10" Width="NaN" Height="40" FontSize="11" VerticalContentAlignment="Center" Background="{x:Null}" PasswordChanged="PasswordBox_PasswordChanged"/>

        

        <Button Content="Войти"
        Grid.Row="3"
        Click="Login_Click" />

        <Grid.RowDefinitions>
            <RowDefinition Height="51*"/>
            <RowDefinition Height="74*"/>
            <RowDefinition Height="63*"/>
            <RowDefinition Height="57*"/>
        </Grid.RowDefinitions>
    </Grid>
</Window>
